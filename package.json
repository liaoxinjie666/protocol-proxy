{
  "name": "protocol-proxy",
  "version": "2.1.5",
  "description": "OpenAI / Anthropic 协议转换透明代理",
  "main": "server.js",
  "bin": {
    "protocol-proxy": "server.js"
  },
  "files": [
    "server.js",
    "lib/",
    "public/",
    "config/",
    "README.md"
  ],
  "keywords": [
    "proxy",
    "openai",
    "anthropic",
    "api",
    "protocol-converter"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "pkg . --out-path=dist"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "puppeteer-core": "^24.43.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": [
      "lib/**/*.js"
    ],
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "dist",
    "options": []
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
