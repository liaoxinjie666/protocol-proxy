{
  "name": "protocol-proxy",
  "version": "3.3.17",
  "description": "OpenAI / Anthropic / Gemini 协议转换透明代理与 AI 运维管理平台",
  "main": "server.js",
  "bin": {
    "protocol-proxy": "server.js"
  },
  "files": [
    "server.js",
    "lib/",
    "public/",
    "config/",
    "agents/",
    "skills/",
    "README.md",
    "README_EN.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "keywords": [
    "proxy",
    "openai",
    "anthropic",
    "gemini",
    "claude",
    "api",
    "protocol-converter",
    "mcp",
    "ai-agent",
    "ai-gateway",
    "llm-proxy",
    "api-gateway"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "pkg . --out-path=dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^4.4.168",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": [
      "lib/**/*.js"
    ],
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "dist",
    "options": []
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
